<?xml version="1.0" encoding="UTF-8"?>
<sbe:messageSchema xmlns:sbe="http://fixprotocol.io/2016/sbe"
                   package="order"
                   id="1"
                   version="1"
                   semanticVersion="1.0.0"
                   description="SBE schema for OrderCommand">

    <!-- Message header -->
    <types>
        <composite name="messageHeader" description="Standard SBE message header" semanticType="messageHeader">
            <type name="blockLength" primitiveType="uint16"/>
            <type name="templateId" primitiveType="uint16"/>
            <type name="schemaId" primitiveType="uint16"/>
            <type name="version" primitiveType="uint16"/>
        </composite>

        <!-- enums -->
        <enum name="OrderCommandType" encodingType="uint8" description="Order command types">
            <validValue name="PlaceOrder" value="0">0</validValue>
            <validValue name="CancelOrder" value="1">1</validValue>
            <validValue name="DepositFunds" value="2">2</validValue>
            <validValue name="WithdrawFunds" value="3">3</validValue>
        </enum>

        <enum name="Side" encodingType="uint8" description="Order Side types">
            <validValue name="Ask" value="0">0</validValue>
            <validValue name="Bid" value="1">1</validValue>
        </enum>

        <enum name="TimeInForce" encodingType="uint8" description="Time In Force specifications">
            <validValue name="Gtc" value="0">0</validValue>
            <validValue name="Ioc" value="1">1</validValue>
            <validValue name="Fok" value="2">2</validValue>
        </enum>

        <enum name="Status" encodingType="uint8" description="Order status specifications">
            <validValue name="Rejected" value="0">0</validValue>
            <validValue name="Placed" value="1">1</validValue>
            <validValue name="Cancelled" value="2">2</validValue>
            <validValue name="PartiallyFilled" value="3">3</validValue>
            <validValue name="Filled" value="4">4</validValue>
            <validValue name="Processing" value="5">5</validValue>
        </enum>
    </types>

    <!-- Message -->
    <message name="OrderCommandMessage" id="1" blockLength="64" semanticType="OrderCommand">
        <field name="command" id="1" type="OrderCommandType"/>
        <field name="client_order_id" id="12" type="uint64"/>
        <field name="order_id" id="2" type="uint64"/>
        <field name="user_id" id="4" type="uint64"/>
        <field name="market_id" id="3" type="uint32"/>
        <field name="price" id="5" type="uint64"/>
        <field name="size" id="7" type="uint64"/>
        <field name="side" id="8" type="Side"/>
        <field name="time_in_force" id="9" type="TimeInForce"/>
        <field name="timestamp" id="10" type="uint64"/>
        <field name="status" id="11" type="Status"/>
    </message>
</sbe:messageSchema>
